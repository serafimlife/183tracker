# Telegram Bot API token from @BotFather
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty (the default) to allow ALL users — correct for a public bot.
# Set to restrict access to specific IDs for a private/personal instance.
# Get your Telegram ID from @userinfobot.
ALLOWED_USER_IDS=

# Async PostgreSQL URL (asyncpg driver)
# Direct/systemd: use localhost as host
# Docker Compose: docker-compose.yml builds this automatically from POSTGRES_* vars below.
DATABASE_URL=postgresql+asyncpg://botuser:change_me@localhost:5432/183days_bot

# PostgreSQL credentials — used by docker-compose.yml to configure the postgres container
# and to build DATABASE_URL for the bot. Generate a strong password:
#   openssl rand -base64 32
POSTGRES_USER=botuser
POSTGRES_PASSWORD=change_me_use_openssl_rand
POSTGRES_DB=183days_bot

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Redis URL for FSM state storage (required for multi-instance / persistent FSM).
# Without this, FSM state is in-memory and lost on restart.
# REDIS_URL=redis://localhost:6379/0
